# --- AI Credentials (at least one required for messaging / selector discovery) ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=
OPENAI_MODEL_NAME=gpt-4o-mini

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# FastAPI Security Authentication Secret Key (required for X-API-Key header verification)
# Must match VITE_BACKEND_API_KEY in the dashboard
BACKEND_API_KEY=your_secure_random_key_here

# Allowed CORS Origins (comma-separated list of origins)
ALLOWED_ORIGINS=http://localhost:5173

# Scraper Settings (aligned with Node backend defaults)
SCRAPE_DELAY_MIN=2000
SCRAPE_DELAY_MAX=5000
SCRAPE_MAX_RETRIES=3
SCRAPE_TIMEOUT=30000

# Scan Cron Schedule (runs once daily at 6:00 AM by default)
SCAN_CRON_SCHEDULE=0 6 * * *

# Database File Path (relative to project root, or absolute)
DB_PATH=./data/monitoring.db

# Reports Output Directory
REPORTS_DIR=./reports

# Optional proxy used on scrape retry #3
PROXY_URL=
